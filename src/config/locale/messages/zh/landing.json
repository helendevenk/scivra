  "introduce": {
    "block": "features-list",
    "id": "introduce",
    "title": "Scivra 是什么？",
    "label": "关于",
    "description": "一个交互式科学学习平台，3D 仿真覆盖物理、化学、生物、地球科学和数学——从 K-2 到 AP 全覆盖。",
    "image": {
      "src": "/imgs/experiments/projectile-motion.png",
      "alt": "Scivra 实验预览"
    },
    "items": [
      {
        "title": "179 个交互实验",
        "description": "横跨 5 大学科的 3D 仿真实验。调整参数，即时看到结果。",
        "icon": "FlaskConical"
      },
      {
        "title": "K-12 + AP 全覆盖",
        "description": "从小学科学到 AP 物理、化学、生物。对齐 NGSS、GCSE 和 AP 课程标准。",
        "icon": "GraduationCap"
      },
      {
        "title": "学习进度追踪",
        "description": "记录学习历程，包括实验次数、挑战完成度和技能进阶。",
        "icon": "BarChart2"
      },
      {
        "title": "隐私优先",
        "description": "符合 GDPR 和 COPPA 规范，为学生数据提供年龄适配的安全保护。",
        "icon": "Shield"
      }
    ],
    "className": "bg-muted"
  },
