{
  "name": "neonphysics-v2",
  "version": "1.6.0",
  "private": true,
  "author": "Scivra",
  "homepage": "https://scivra.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/scivra/scivra"
  },
  "keywords": [
    "scivra",
    "k12-science",
    "interactive-experiments",
    "ap-physics",
    "ngss",
    "education",
    "upg"
