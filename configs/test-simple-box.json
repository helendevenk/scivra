{
  "metadata": {
    "id": "test-simple-box",
    "title": "测试实验",
    "subtitle": "验证生成器系统",
    "icon": "🧪",
    "grade": "3-5",
    "subject": "physics"
  },

  "scene": {
    "background": "gradient",
    "lighting": "three-point",
    "camera": {
      "position": [0, 5, 15],
      "fov": 60
    }
  },

  "objects": [
    {
      "type": "box",
      "geometry": "box",
      "material": "metal",
      "color": "0x3B82F6",
      "position": [0, 0, 0],
      "scale": [2, 2, 2],
      "castShadow": true,
      "receiveShadow": true
    },
    {
      "type": "ground",
      "geometry": "plane",
      "material": "plastic",
      "color": "0x1a1a2e",
      "position": [0, -2, 0],
      "rotation": [-1.57, 0, 0],
      "scale": [20, 20, 1],
      "receiveShadow": true
    },
    {
      "type": "particles",
      "count": 500,
      "size": 0.05,
      "color": "0x00c6ff",
      "spread": 10
    }
  ],

  "controls": [
    {
      "id": "rotation-speed",
      "type": "slider",
      "label": "旋转速度",
      "min": 0,
      "max": 5,
      "default": 1,
      "step": 0.1,
      "decimals": 1,
      "onChange": "object1.rotation.y += value * 0.01;"
    },
    {
      "id": "box-scale",
      "type": "slider",
      "label": "方块大小",
      "min": 0.5,
      "max": 5,
      "default": 2,
      "step": 0.5,
      "decimals": 1,
      "onChange": "object1.scale.setScalar(value);"
    }
  ],

  "customCode": {
    "animation": "object1.rotation.y += 0.01; particleSystem3.update();"
  }
}
