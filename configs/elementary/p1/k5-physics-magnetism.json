  "formulas": [
    {
      "title": "磁场力",
      "formula": "F = qvB\\sin\\theta",
      "description": "其中 F 是磁场力，q 是电荷量，v 是速度，B 是磁场强度，θ 是速度与磁场的夹角"
    },
    {
      "title": "磁场强度",
      "formula": "B = \\frac{\\mu_0 I}{2\\pi r}",
      "description": "其中 B 是磁场强度，μ₀ 是真空磁导率，I 是电流，r 是距离"
    }
  ],

  "knowledgeCards": [
    {
      "title": "🧲 什么是磁力？",
      "content": "磁力是磁铁或磁场对铁磁性物质产生的吸引力或排斥力。磁铁有两个磁极：北极（N）和南极（S）。"
    },
    {
      "title": "🔄 磁力线",
      "content": "磁力线是用来描述磁场方向和强度的假想曲线。磁力线从北极出发，进入南极，在磁铁内部从南极回到北极。"
    },
    {
      "title": "⚡ 同极相斥，异极相吸",
      "content": "两个磁铁的同名磁极（N-N 或 S-S）会相互排斥，异名磁极（N-S）会相互吸引。这是磁力的基本规律。"
    },
    {
      "title": "🌍 地球磁场",
      "content": "地球本身就是一个巨大的磁铁，有南北两个磁极。指南针的指针就是利用地球磁场来指示方向的。"
    },
    {
      "title": "🔬 磁性材料",
      "content": "铁、钴、镍等金属具有磁性，可以被磁铁吸引。这些材料被称为铁磁性材料。"
    }
  ],

  "quiz": [
    {
      "question": "磁铁有几个磁极？",
      "options": [
        "1个",
        "2个",
        "3个",
        "4个"
      ],
      "correctIndex": 1,
      "explanation": "磁铁有两个磁极：北极（N）和南极（S）。无论磁铁被切成多小，每一块都有两个磁极。"
    },
    {
      "question": "两个磁铁的北极靠近时会发生什么？",
      "options": [
        "相互吸引",
        "相互排斥",
        "没有反应",
        "产生电流"
      ],
      "correctIndex": 1,
      "explanation": "同名磁极（N-N 或 S-S）会相互排斥，异名磁极（N-S）会相互吸引。"
    }
  ],

