# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "5"  # Connection pool size (default: 5, production: 10)

# redis (Upstash)
UPSTASH_REDIS_REST_URL = ""  # Get from https://upstash.com
UPSTASH_REDIS_REST_TOKEN = ""

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# UPG AI generation — pick one provider:
# Option A: Anthropic-compatible proxy (recommended, e.g. BigModel GLM)
ANTHROPIC_AUTH_TOKEN = ""      # API token for Anthropic-compatible endpoint
ANTHROPIC_BASE_URL = ""        # e.g. https://open.bigmodel.cn/api/anthropic
OPUS_MODEL = ""                # Model ID, e.g. glm-5-turbo

# Option B: Anthropic direct
# ANTHROPIC_API_KEY = ""       # Get from https://console.anthropic.com

# Option C: OpenRouter (supports Claude via proxy)
# OPENROUTER_API_KEY = ""      # Get from https://openrouter.ai

# UPG Review (PackyAPI — OpenAI-compatible proxy for experiment quality review)
PACKY_API_KEY = ""             # Get from https://www.packyapi.com
PACKY_API_BASE_URL = "https://www.packyapi.com/v1"

# Payment providers (Stripe / PayPal / Creem)
# 凭据不在这里配，统一通过 admin 面板 /admin/settings/payment 写入 DB configs 表
# 详见 docs/payment/stripe-setup.md